# Copy ALL lines below into Vercel → Project → Settings → Environment Variables
# (Production + Preview). Values: copy from your local .env.local — never commit .env.local.

SKIP_ENV_VALIDATION=true

# Supabase
NEXT_PUBLIC_SUPABASE_PROJECT_REF=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
DATABASE_SERVICE_ROLE=

# Database
DATABASE_URL=

# AWS S3 (demo bucket ok)
NEXT_PUBLIC_S3_BUCKET=hiyori-backpack
NEXT_PUBLIC_S3_REGION=us-west-2
S3_ACCESS_KEY_ID=placeholder
S3_SECRET_ACCESS_KEY=placeholder

# Stripe (placeholders until Razorpay/Stripe setup)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECERT_KEY=whsec_placeholder

# Deployment — use your Vercel URL after first deploy
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app
